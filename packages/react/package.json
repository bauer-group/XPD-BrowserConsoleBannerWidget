{
  "name": "@bauer-group/console-security-banner-react",
  "version": "0.0.0",
  "description": "React 19 component & hook for the BAUER GROUP Console Security Banner — warns end users about Self-XSS scams in the browser console. Local-bundled (zero requests) by default, optional CDN mode.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "jsdom": "^29.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "react",
    "react19",
    "console",
    "security",
    "self-xss",
    "banner",
    "devtools",
    "bauer-group"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bauer-group/XPD-BrowserConsoleBannerWidget.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/bauer-group/XPD-BrowserConsoleBannerWidget/tree/main/packages/react"
}
